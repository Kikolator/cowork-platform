# ── Edge Function secrets ──────────────────────────────────────
# Set these via: supabase secrets set --env-file supabase/functions/.env
# Or individually: supabase secrets set RESEND_API_KEY=re_...

# Resend API key — same key as the web app uses
# Create at https://resend.com/api-keys
RESEND_API_KEY=re_...

# Webhook signing secret for the send_email auth hook
# Generate in Supabase Dashboard → Auth → Hooks → Send Email → Generate Secret
# IMPORTANT: strip the "v1,whsec_" prefix — store only the base64 part
SEND_EMAIL_HOOK_SECRET=

# Platform domain used to resolve space subdomains from redirect URLs
# Must match NEXT_PUBLIC_PLATFORM_DOMAIN in the web app
PLATFORM_DOMAIN=rogueops.app

# ── Auto-injected by Supabase (do NOT set manually) ──────────
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
