# App environment — controls dev-only features (e.g. password auth)
# Set to "development" for local/preview, omit or set "production" for prod
NEXT_PUBLIC_APP_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUB_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key

# Platform domain config
NEXT_PUBLIC_PLATFORM_DOMAIN=localhost:3000

# Stripe Connect
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# Resend (transactional email)
# Create API key at https://resend.com/api-keys
# Verify your sending domain at https://resend.com/domains (must match noreply@rogueops.app)
RESEND_API_KEY=re_...

# Vercel Domains API (custom domain management)
# Generate token at https://vercel.com/account/tokens
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# Cron job auth
CRON_SECRET=your-cron-secret
