{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ../../packages/",
  "git": {
    "deploymentEnabled": {
      "*": false,
      "main": true,
      "dev": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/renew-credits",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/pass-lifecycle",
      "schedule": "5 0 * * *"
    }
  ]
}
